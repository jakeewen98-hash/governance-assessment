# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic Claude API — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Email delivery (optional but recommended) ──────────────────────────────────
# Resend — https://resend.com (free tier: 3,000 emails/month)
# 1. Sign up at resend.com
# 2. Create an API key
# 3. Add your sending domain (or use the Resend test address for dev)
RESEND_API_KEY=re_...

# The From address shown on emails. Must use a domain verified in Resend.
# During development you can use: "Themis Partners <onboarding@resend.dev>"
# and Resend will deliver to your own email only.
RESEND_FROM_EMAIL=Themis Partners <reports@themis-partners.co.uk>

# ── Optional ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
